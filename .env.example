# ============================================================================
# NeuroLens — Environment variables (example template)
# ----------------------------------------------------------------------------
# Copy this file to .env and fill in real values.
# .env is gitignored — NEVER commit it.
# ============================================================================

# --- PostgreSQL ----------------------------------------------------------
# Superuser password (only used for admin/maintenance inside container)
POSTGRES_SUPERUSER_PASSWORD=replace-with-strong-random-32-chars

# Restricted application user password (used by neurolens code)
POSTGRES_NEUROLENS_WRITER_PASSWORD=replace-with-strong-random-32-chars

# Connection string used by the neurolens Python code
# Format: postgresql://<user>:<password>@<host>:<port>/<db>?sslmode=require
# Host is the VPS public IP/DNS; port is 5434 (Docker mapping); SSL required.
DATABASE_URL=postgresql://neurolens_writer:PASSWORD@your.vps.host:5434/neurolens?sslmode=require

# --- Weights & Biases ----------------------------------------------------
# Get at https://wandb.ai/authorize (account-level token, works for all W&B products)
WANDB_API_KEY=wandb_v1_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
